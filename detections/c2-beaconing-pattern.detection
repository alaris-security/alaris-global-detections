  ],
  "rules": ["rules/siem/c2-beaconing-pattern.sigma"],
  "intent": {
    "conditions": [
      "More than 30 outbound connections from one source to one destination/port within an hour",
      "Inter-arrival times have low standard deviation (jitter < 30%)"
    ],
    "dataSourceRequirements": [
      "Network connection telemetry with timestamps (Sysmon EID 3, firewall, NetFlow, or proxy)"
    ],
    "tuningParameters": {
      "minConnectionsPerHour": 30,
      "maxJitterPercent": 30,
      "allowedDestinations": []
    },
    "sourceContext": "Most C2 frameworks beacon at a configured interval with optional jitter; periodicity is a behavioral, infrastructure-agnostic signal."
  }
}
