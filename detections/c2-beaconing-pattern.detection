{
  "slug": "c2-beaconing-pattern",
  "title": "C2 Beaconing Pattern",
  "description": "Detects periodic outbound HTTP/HTTPS connections from a single host to a single destination, characteristic of implant beaconing to a command and control server.",
  "severity": "low",
  "families": ["siem"],
  "tags": ["command-and-control", "beacon", "periodicity", "implant"],
  "status": "active",
  "mitre": [
